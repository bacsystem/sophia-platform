# ─── Database (PostgreSQL 16) ───────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sophia
DB_USER=sophia
DB_PASSWORD=sophia
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ─── Redis 7 ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ─── JWT ────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# ─── Encryption (AES-256-GCM para API keys) ────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── Email ──────────────────────────────────────────────
# Producción: Resend | Desarrollo: console (logs en terminal)
EMAIL_PROVIDER=console
RESEND_API_KEY=

# ─── Anthropic ──────────────────────────────────────────
# No se usa API key del sistema. Cada usuario configura la suya en Settings (M7).
# Esta variable es solo para pruebas en desarrollo.
ANTHROPIC_API_KEY=

# ─── Projects ───────────────────────────────────────────
PROJECTS_BASE_DIR=./projects

# ─── API Server ─────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# ─── Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ─── BullMQ Worker ──────────────────────────────────────
WORKER_CONCURRENCY=3
AGENT_TIMEOUT_MS=300000
