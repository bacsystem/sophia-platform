{
  "openapi": "3.0.3",
  "info": {
    "title": "Sophia Platform — M1 Auth API",
    "version": "1.2.0",
    "description": "Endpoints de autenticación para Sophia Platform"
  },
  "servers": [
    { "url": "http://localhost:3001", "description": "Local dev" }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Crear cuenta",
        "operationId": "register",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registro exitoso — Set-Cookie: access_token, refresh_token",
            "headers": {
              "Set-Cookie": { "schema": { "type": "string" } }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserResponse" }
              }
            }
          },
          "409": {
            "description": "Email ya existe",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "error": "EMAIL_ALREADY_EXISTS", "message": "El email ya está registrado" }
              }
            }
          },
          "422": {
            "description": "Error de validación",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationErrorResponse" }
              }
            }
          },
          "429": {
            "description": "Rate limit excedido",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RateLimitErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Iniciar sesión",
        "operationId": "login",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login exitoso — Set-Cookie: access_token, refresh_token",
            "headers": {
              "Set-Cookie": { "schema": { "type": "string" } }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserResponse" }
              }
            }
          },
          "401": {
            "description": "Credenciales incorrectas",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "error": "INVALID_CREDENTIALS", "message": "Credenciales incorrectas" }
              }
            }
          },
          "429": {
            "description": "Cuenta bloqueada por rate limit",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RateLimitErrorResponse" },
                "example": { "error": "TOO_MANY_ATTEMPTS", "message": "Cuenta bloqueada por 15 minutos", "retryAfter": 900 }
              }
            }
          }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "summary": "Rotar tokens",
        "operationId": "refresh",
        "tags": ["Auth"],
        "description": "No requiere body. Usa cookie refresh_token.",
        "responses": {
          "200": {
            "description": "Tokens rotados — Set-Cookie: access_token (nuevo), refresh_token (nuevo)",
            "headers": {
              "Set-Cookie": { "schema": { "type": "string" } }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserResponse" }
              }
            }
          },
          "401": {
            "description": "Refresh token inválido o expirado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "error": "INVALID_REFRESH_TOKEN", "message": "Sesión expirada" }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "Cerrar sesión",
        "operationId": "logout",
        "tags": ["Auth"],
        "description": "No requiere body. Usa cookie refresh_token. Revoca el token en BD.",
        "responses": {
          "200": {
            "description": "Sesión cerrada — Clear-Cookie: access_token, refresh_token",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": { "type": "string", "example": "Sesión cerrada" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/forgot-password": {
      "post": {
        "summary": "Solicitar reset de contraseña",
        "operationId": "forgotPassword",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ForgotPasswordInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Siempre 200 (no revela si el email existe)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": { "type": "string", "example": "Si el email existe, recibirás instrucciones" }
                      }
                    }
                  }
                }
              }
            }
          },
          "429": {
            "description": "Rate limit excedido",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RateLimitErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/auth/reset-password": {
      "post": {
        "summary": "Resetear contraseña con token",
        "operationId": "resetPassword",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ResetPasswordInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contraseña actualizada",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": { "type": "string", "example": "Contraseña actualizada exitosamente" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Token inválido o expirado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "error": "INVALID_TOKEN", "message": "Token inválido o expirado" }
              }
            }
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "summary": "Obtener usuario autenticado",
        "operationId": "getMe",
        "tags": ["Auth"],
        "description": "Requiere cookie access_token válida.",
        "responses": {
          "200": {
            "description": "Usuario autenticado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MeResponse" }
              }
            }
          },
          "401": {
            "description": "No autenticado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "error": "UNAUTHORIZED", "message": "No autenticado" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RegisterInput": {
        "type": "object",
        "required": ["name", "email", "password"],
        "properties": {
          "name": { "type": "string", "minLength": 2, "maxLength": 100 },
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 8, "description": "Mínimo 8 caracteres con al menos 1 número" }
        }
      },
      "LoginInput": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 1 },
          "rememberMe": { "type": "boolean", "default": false }
        }
      },
      "ForgotPasswordInput": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "format": "email" }
        }
      },
      "ResetPasswordInput": {
        "type": "object",
        "required": ["token", "password"],
        "properties": {
          "token": { "type": "string" },
          "password": { "type": "string", "minLength": 8 }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "name": { "type": "string" },
              "email": { "type": "string", "format": "email" }
            }
          }
        }
      },
      "MeResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "name": { "type": "string" },
              "email": { "type": "string", "format": "email" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "ValidationErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "example": "VALIDATION_ERROR" },
          "message": { "type": "string" },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": { "type": "array", "items": { "type": "string" } },
                "message": { "type": "string" }
              }
            }
          }
        }
      },
      "RateLimitErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" },
          "retryAfter": { "type": "integer", "description": "Segundos hasta poder reintentar" }
        }
      }
    }
  }
}
